{
  "name": "private",
  "version": "1.0.0",
  "license": "MIT",
  "author": "zhangbo <zhangbo3.vendor@sensetime.com>",
  "repository": "https://github.com/Promisezhangbo/private.git",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_ENV=production && rm -rf dist && turbo run build --filter=./apps/*",
    "dev": "node ./scripts/dev.mjs",
    "lint": "turbo run lint --filter=./apps/*",
    "typecheck": "turbo run typecheck --filter=./apps/* --filter=@packages/openapi",
    "generate": "turbo run generate --filter=@packages/openapi",
    "lint:style": "stylelint \"{apps,packages}/**/*.{css,scss}\" --fix --allow-empty-input",
    "format": "oxfmt",
    "prepare": "husky",
    "postbuild": "cp dist/main/index.html dist/404.html && cp dist/main/index.html dist/index.html && echo '/*  /main/index.html  200' > dist/_redirects",
    "reinit": "bash ./scripts/clean.sh"
  },
  "dependencies": {
    "cross-env": "^10.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@packages/stylelint-config": "workspace:*",
    "@packages/ts-config": "workspace:*",
    "@types/node": "^24.10.11",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "stylelint": "^16.11.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "turbo": "^2.9.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  },
  
  "packageManager": "pnpm@10.13.1"
}