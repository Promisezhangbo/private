{
  "name": "private",
  "version": "1.0.0",
  "type": "module",
  "repository": "https://github.com/Promisezhangbo/private.git",
  "author": "zhangbo <zhangbo3.vendor@sensetime.com>",
  "license": "MIT",
  "scripts": {
    "prebuild": "pnpm --filter @packages/openapi run generate",
    "predev": "pnpm --filter @packages/openapi run generate",
    "build": "cross-env NODE_ENV=production && rm -rf dist && pnpm --parall --filter \"./apps/*\" build",
    "dev": "cross-env NODE_ENV=development && pnpm --parall --filter \"./apps/*\" dev",
    "lint": "pnpm --parall --filter \"./apps/*\" lint",
    "lint:style": "stylelint \"**/*.{css,scss}\" --fix --allow-empty-input",
    "format": "oxfmt --fix",
    "prepare": "husky",
    "postbuild": "cp dist/main/index.html dist/404.html && cp dist/main/index.html dist/index.html && echo '/*  /main/index.html  200' > dist/_redirects",
    "reinit": "pnpm -r exec rm -rf node_modules && rm -rf node_modules pnpm-lock.yaml && pnpm install"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@packages/stylelint-config": "workspace:*",
    "@packages/ts-config": "workspace:*",
    "@types/node": "^24.10.11",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "stylelint": "^16.11.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,vue}": [
      "pnpm lint"
    ],
    "**/*.{css,scss}": [
      "stylelint --fix --allow-empty-input",
      "pnpm lint"
    ],
    "**/*.{json,md}": [
      "pnpm lint"
    ]
  },
  "dependencies": {
    "cross-env": "^10.1.0"
  }
}