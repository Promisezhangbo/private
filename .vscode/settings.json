{
  // 强制当前项目所有 JS/TS/Vue 等文件用 Prettier 格式化
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // 开启保存格式化，且仅触发 Prettier
  "editor.formatOnSave": true,
  // 禁用 ESLint 自动修复（和全局设置呼应）
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "never"
  },
  // 确保 Prettier 优先于其他工具
  "prettier.enable": true,
  "eslint.format.enable": false // 禁止 ESLint 作为格式化工具
}
