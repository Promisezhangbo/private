# Demo：复制为 .env.local 后按需填写。pnpm dev:db 只加载 .env.local，不读本文件。

# 必填：Postgres 连接串（占位符，请换成你在控制台复制的真实地址）
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# 可选：表名不是 blogs 时填写（须与库里真实表名一致）
# BLOG_TABLE=my_blogs

# 可选：持仓成本记录表名，默认 stock
# STOCK_TABLE=stock

# 可选：额外允许的浏览器 Origin（逗号或空白分隔，须含协议，如 https://your-domain.com）
# 内置已含 promisezhangbo.github.io、*.netlify.app、localhost；自定义域名或预览站可在此追加。
# CORS_ALLOWED_ORIGINS=https://example.com
