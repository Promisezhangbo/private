# Demo：复制为 .env.local 后按需填写。pnpm dev:env 只加载 .env.local，不读本文件。
# 时间、文案等请在 src/business/wecom/bots/settings.ts 中修改。

# 可选：本地 HTTP 端口，默认 8787
# BOT_SERVER_PORT=8787

# 必填：各机器人 webhook（企业微信群 → 群机器人）
WECOM_OFF_WORK_WEBHOOK_URL=
WECOM_ON_WORK_WEBHOOK_URL=

# 可选：手动触发接口鉴权；非空时请求需带 ?token=xxx
# BOT_TRIGGER_TOKEN=

# 可选：额外允许的浏览器 Origin
# CORS_ALLOWED_ORIGINS=https://example.com
