{
  "nodeModulesDir": "auto",
  "unstable": ["sloppy-imports", "cron"],
  "compilerOptions": {
    "lib": ["deno.ns", "deno.unstable", "esnext", "dom"]
  },
  "imports": {
    "hono": "npm:hono@4.6.12",
    "hono/cors": "npm:hono@4.6.12/cors",
    "hono/logger": "npm:hono@4.6.12/logger"
  },
  "tasks": {
    "dev": "deno run --allow-net --allow-env --allow-read --watch src/main.ts",
    "dev:env": "deno run --allow-net --allow-env --allow-read --env-file=.env.local --watch src/main.ts",
    "check": "deno check src/main.ts"
  },
  "deploy": {
    "runtime": {
      "type": "dynamic",
      "entrypoint": "./src/main.ts"
    }
  },
  "exclude": ["node_modules"]
}
