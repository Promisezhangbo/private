{
  "name": "@packages/openapi",
  "version": "1.0.0",
  "private": true,
  "description": "OpenAPI 多 YAML 生成：由 openapi-axios-sdk（openapi-gen）从 api/*.yaml 生成 gen/，各子应用从本包聚合入口与 *-gen-types 引用。",
  "type": "module",
  "exports": {
    ".": {
      "types": "./gen/index.ts",
      "import": "./gen/index.ts",
      "default": "./gen/index.ts"
    },
    "./*-gen": {
      "types": "./gen/*-gen/index.ts",
      "import": "./gen/*-gen/index.ts",
      "default": "./gen/*-gen/index.ts"
    },
    "./*-gen-types": {
      "types": "./gen/*-gen/types.ts",
      "import": "./gen/*-gen/types.ts",
      "default": "./gen/*-gen/types.ts"
    }
  },
  "scripts": {
    "generate": "openapi-gen -c ./openapi.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "openapi-axios-sdk": "^0.2.2"
  },
  "devDependencies": {
    "typescript": "~5.9.3"
  }
}
