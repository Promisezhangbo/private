{
  "name": "@packages/openapi",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "OpenAPI 生成类型 + 可选 Axios SDK（OpenApiFn）。类型子路径 @packages/openapi/types 无运行时，便于业务自建 axios。",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/openapi.types.ts",
      "import": "./src/openapi.types.ts",
      "default": "./src/openapi.types.ts"
    }
  },
  "scripts": {
    "generate": "node ./scripts/generate.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@hey-api/client-axios": "0.9.1",
    "@hey-api/openapi-ts": "0.94.5",
    "typescript": "~5.9.3"
  }
}
