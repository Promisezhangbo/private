{
  "name": "@packages/openapi",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "OpenAPI 多 YAML 生成：每个 <name>.yaml → <name>-gen/（独立域名/Token/baseURL）。根入口仅导出公共初始化器。",
  "exports": {
    ".": {
      "types": "./src/request.ts",
      "import": "./src/request.ts",
      "default": "./src/request.ts"
    },
    "./*-gen": {
      "types": "./src/*-gen/index.ts",
      "import": "./src/*-gen/index.ts",
      "default": "./src/*-gen/index.ts"
    },
    "./*-gen-types": {
      "types": "./src/*-gen/types.ts",
      "import": "./src/*-gen/types.ts",
      "default": "./src/*-gen/types.ts"
    }
  },
  "scripts": {
    "generate": "node ./scripts/generate.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@hey-api/client-axios": "0.9.1",
    "@hey-api/openapi-ts": "0.94.5",
    "typescript": "~5.9.3"
  }
}
